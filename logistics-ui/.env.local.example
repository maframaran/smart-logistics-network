# Copy this file to .env.local for local development

# Backend service URLs (use localhost for local dev; Docker sets service names)
SHIPMENT_SERVICE_URL=http://localhost:8081
FLEET_SERVICE_URL=http://localhost:8082
DRIVER_SERVICE_URL=http://localhost:8083
ROUTING_SERVICE_URL=http://localhost:8084
WAREHOUSE_SERVICE_URL=http://localhost:8085
BILLING_SERVICE_URL=http://localhost:8086
NOTIFICATION_SERVICE_URL=http://localhost:8087

# Auth.js — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000
